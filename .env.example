# ============================================================
# NBA Enterprise AI Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------
APP_NAME=NBA_Enterprise_AI_Platform
APP_ENV=production
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# ------------------------------------------------------------
# POSTGRESQL
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nba_platform
POSTGRES_USER=nba_admin
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql+asyncpg://nba_admin:your-postgres-password@localhost:5432/nba_platform

# ------------------------------------------------------------
# MONGODB
# ------------------------------------------------------------
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=nba_platform_nosql
MONGO_USER=nba_mongo_admin
MONGO_PASSWORD=your-mongo-password
MONGO_URI=mongodb://nba_mongo_admin:your-mongo-password@localhost:27017/nba_platform_nosql

# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@localhost:6379/0

# ------------------------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# OPENAI
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# ------------------------------------------------------------
# IBM WATSONX / GRANITE
# ------------------------------------------------------------
WATSONX_API_KEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2
GRANITE_MAX_TOKENS=4096
GRANITE_TEMPERATURE=0.2

# ------------------------------------------------------------
# SENTENCE TRANSFORMERS / RAG
# ------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=vector_db/faiss_index
FAISS_DIMENSION=384
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ------------------------------------------------------------
# LLM ROUTING
# ------------------------------------------------------------
# Options: openai | granite | auto
DEFAULT_LLM_PROVIDER=auto
LLM_FALLBACK_PROVIDER=openai

# ------------------------------------------------------------
# MONITORING — PROMETHEUS
# ------------------------------------------------------------
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# ------------------------------------------------------------
# FILE STORAGE
# ------------------------------------------------------------
DATA_DIR=data
UPLOAD_DIR=data/uploads
GENERATED_PDF_DIR=data/generated_pdfs
MAX_UPLOAD_SIZE_MB=50

# ------------------------------------------------------------
# CORS & SECURITY
# ------------------------------------------------------------
CORS_MAX_AGE=600
RATE_LIMIT_PER_MINUTE=60
BCRYPT_ROUNDS=12

# ------------------------------------------------------------
# STREAMLIT (optional dashboard)
# ------------------------------------------------------------
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# ------------------------------------------------------------
# FRONTEND (Vite / React)
# ------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=NBA Accreditation Platform
VITE_APP_VERSION=1.0.0
